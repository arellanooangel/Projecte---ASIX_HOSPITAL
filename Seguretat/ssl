# **Pas 1: Generació del Certificat (Servidor Linux)**
# 1. Executar els següents comandos per a instal·lar certbot, que és una eina per a obtenir i renovar certificats SSL
sudo apt update
sudo apt install certbot -y

# 2. Obtenir un certificat SSL per al teu domini. Assegura't de substituir l'IP "192.168.2.5" per la teva.
# Si tens port 80 obert
sudo certbot certonly --standalone -d 192.168.2.5

# **Pas 2: Automatització i Permisos (Script de Hook)**
# 1. Crear el fitxer: sudo nano /etc/letsencrypt/renewal-hooks/deploy/postgres-ssl.sh
# 2. Enganxar aquest codi:

# Configura el teu domini i ruta de dades de Postgres
DOMAIN="192.168.2.5"
PG_DATA="/var/lib/postgresql/16/main"

# Copiar fitxers
cp /etc/letsencrypt/live/$DOMAIN/fullchain.pem $PG_DATA/server.crt
cp /etc/letsencrypt/live/$DOMAIN/privkey.pem $PG_DATA/server.key

# Permisos estrictes (Postgres els exigeix)
chown postgres:postgres $PG_DATA/server.crt $PG_DATA/server.key
chmod 600 $PG_DATA/server.key

# Recarregar el servei
systemctl reload postgresql


# 3. Donar permisos d'execució:
sudo chmod +x /etc/letsencrypt/renewal-hooks/deploy/postgres-ssl.sh

# **Pas 3: Configuració de Postgres**
# Hem de dir-li a la base de dades que usi aquests fitxers i que obligui a connectar amb SSL.

# 1. Editar postgresql.conf:
sudo nano /etc/postgresql/16/main/postgresql.conf

# Modifica aquestes línies:
ssl = on
ssl_cert_file = '/var/lib/postgresql/16/main/server.crt'
ssl_key_file = '/var/lib/postgresql/16/main/server.key'

# 2. Editar pg_hba.conf (Restricció d'accés):
sudo nano /etc/postgresql/16/main/pg_hba.conf

# Afegeix o modifica aquestes línies al final per forçar SSL:
# Forçar SSL per a connexions externes
hostssl all             all             0.0.0.0/0               scram-sha-256
# Rebutjar connexions no xifrades
hostnossl all           all             0.0.0.0/0               reject

# 3. Reiniciar el servei:
sudo systemctl restart postgresql


